# Update values for your environment.
NEXT_PUBLIC_APP_NAME=REVEL Portal
PORTAL_SESSION_SECRET=replace-with-long-random-secret
PORTAL_ENABLE_DEV_ROLE_SWITCH=false

# Supabase (required for persistent onboarding saves)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional outbound channels (leave blank to run in simulation mode)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# AI — Gemini (leave blank to run in simulation mode using regex extraction)
GEMINI_API_KEY=

# Stripe checkout + webhook (required for real payment processing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_APP_URL=
